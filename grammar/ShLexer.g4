lexer grammar ShLexer;

VAR :'متغير';
IF :'لو' | 'إذا' | 'اذا';
ELSE :'والا' | 'وإلا';
WHILE :'بينما';
PRINT :'اكتب';
TRUE :'صح';
FALSE :'غلط';
INT_T :'صحيح';
FLOAT_T :'عشري';

ASSIGN :'=';
PLUS :'+';
MINUS :'-';
MUL :'*';
DIV :'/';
GT :'>';
LT :'<';
LPAREN :'(';
RPAREN :')';
LBRACE :'{';
RBRACE :'}';
COLON :':';
SEMI :'؛';
